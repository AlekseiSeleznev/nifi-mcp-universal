# ── Gateway ──────────────────────────────────────────
NIFI_MCP_PORT=8080
NIFI_MCP_LOG_LEVEL=INFO

# Optional: Bearer token for MCP endpoint auth
# NIFI_MCP_API_KEY=

# ── Default NiFi connection (auto-connect on start) ──
# NIFI_MCP_NIFI_API_BASE=https://nifi.example.com/nifi-api
# NIFI_MCP_NIFI_READONLY=true
# NIFI_MCP_VERIFY_SSL=true

# ── Auth (for default connection) ────────────────────
# Certificate (P12):
# NIFI_MCP_NIFI_CLIENT_P12=/data/certs/default/keystore.p12
# NIFI_MCP_NIFI_CLIENT_P12_PASSWORD=changeit

# Knox JWT:
# NIFI_MCP_KNOX_TOKEN=eyJ...

# Basic auth:
# NIFI_MCP_KNOX_USER=admin
# NIFI_MCP_KNOX_PASSWORD=admin

# ── HTTP ─────────────────────────────────────────────
NIFI_MCP_HTTP_TIMEOUT=30
NIFI_MCP_SESSION_TIMEOUT=28800
